{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "baseDomain",
    "certManager",
    "mainEnvVars",
    "tls",
    "wwwBucketHostname"
  ],
  "properties": {
    "baseDomain": {
      "type": "string",
      "minLength": 1
    },
    "mainEnvVars": {
      "type": "object",
      "minProperties": 1
    },
    "wwwBucketHostname": {
      "type": "string",
      "minLength": 1
    },
    "tls": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "secretName": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "certManager": {
      "type": "object",
      "required": [
        "enabled",
        "issuerRef"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "issuerRef": {
          "type": "object",
          "required": [
            "kind",
            "name"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
